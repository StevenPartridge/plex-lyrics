{
  "manifest_version": 3,
  "name": "Plex Lyrics PiP",
  "version": "2.1",
  "description": "Shows Plex Web lyrics in a local Picture-in-Picture window.",
  "minimum_chrome_version": "116",
  "content_scripts": [
    {
      "matches": [
        "https://app.plex.tv/*"
      ],
      "js": ["lyrics-status.js", "pip-page.js"],
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "Plex Lyrics PiP",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{bb57550a-75f8-4fed-8d36-568f2c74d4d9}",
      "strict_min_version": "151.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
